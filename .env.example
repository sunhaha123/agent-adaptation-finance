# ===== LLM 配置 =====
LLM_PROVIDER=openai              # openai 或 anthropic
LLM_BASE_URL=https://api.openai.com/v1/  # OpenAI 兼容接口地址（anthropic 时不需要）
LLM_MODEL=gpt-4.1-mini           # 模型名
LLM_MAX_TOKENS=4096              # 最大输出 token
LLM_API_KEY=your-api-key

# ===== LangSmith 追踪（可选） =====
LANGCHAIN_API_KEY=your-langchain-api-key
LANGSMITH_PROJECT=agent-finance-sim
LANGSMITH_TRACING_V2=true
